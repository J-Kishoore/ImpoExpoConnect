PORT=5000
NODE_ENV=development

# Frontend origin allowed to call this API
CORS_ORIGIN=http://localhost:5173

# JWT session tokens
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h

# Required to allow POST /api/admin/register — leave unset to disable
# admin self-registration entirely (seed the first admin via Firestore console instead).
ADMIN_INVITE_CODE=

# Firebase Admin SDK credentials — from your Firebase service account JSON
# (Project Settings -> Service Accounts -> Generate New Private Key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
